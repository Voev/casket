#include <gtest/gtest.h>

#include <casket/log/async_logger.hpp>
#include <casket/log/console.hpp>

#include <sstream>
#include <string>

using namespace casket;
using namespace testing;

class LogMacrosTest : public ::testing::Test
{
protected:
    void SetUp() override
    {
        auto& manager = AsyncLogger::Instance();
        manager.setMinLevel(LogLevel::DEBUG);
        manager.addSink(new ConsoleSink());
    }
    
    void TearDown() override
    {
    }
};

// Тест 1: Проверка базового логирования
TEST_F(LogMacrosTest, BasicLogging)
{
    LOG_INFO("%s", "Test message");
}
